  "CanContainContent": true,
  "IsBetaVersion": false,
  "IsExperimentalVersion": false,
  "Installed": false,
  "Modules": [
    {
      "Name": "SGAISpeechRecognizer",
      "Type": "Runtime",
      "LoadingPhase": "Default",
      "PlatformAllowList": [
        "Win64",
        "Android"
      ]
    },
    {
      "Name": "VoiceAISpeechRecognizerWindows",
      "Type": "Runtime",
      "LoadingPhase": "None",
      "PlatformAllowList": [
        "Win64"
      ]
    },
    {
      "Name": "VoiceAISpeechRecognizerAndroid",
      "Type": "Runtime",
      "LoadingPhase": "None",
      "PlatformAllowList": [
        "Android"
      ]
    }
  ],
  "Plugins": [
    {
      "Name": "AudioCapture",
      "Enabled": true
    },
    {
      "Name": "QAIRT",
      "Enabled": true
    }
  ]
