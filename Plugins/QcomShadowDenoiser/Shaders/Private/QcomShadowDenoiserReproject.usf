// Device Z (depth) to linear depth
// float DeviceToLinearDepth(float2 ViewportUV, float DeviceDepth)
// {
//	return ConvertFromDeviceZ(DeviceDepth);
//}

// Implement "void ReadReprojectedFrameData(uint2 InScreenLoc, out DepthPositionData Output)"
// which is called from inside the (shared) Reproject() function
struct DepthPositionData
{
	float	CurrentLinearDepth;						// Depth sampled for the current frame.
	float2	ReprojectedUV;							// Current position reprojected into the previous frame's view.
	float	ReprojectedLinearDepth;					// Current depth reprojected into the previous frame's view
	float	HistoryLinearDepth;						// Depth sampled at ReprojectedUV for the previous frame.
};

bool ReadAndReprojectPositionData(uint2 InScreenLoc, out DepthPositionData Output)
{
	// Read out current depth value.
	float CurrentDeviceZ = SceneDepthTexture.Load(int3(InScreenLoc, 0)).x;

	// Reproject the depth into the previous frame's space and use to predict where our screen pixel was last frame.
	float2 CurrentBufferUV = (float2(InScreenLoc) + float2(0.5, 0.5)) * ThreadIdToBufferUV.xy + ThreadIdToBufferUV.zw;
	float3 CurrentScreenPosition = float3(ViewportUVToScreenPos(CurrentBufferUV), CurrentDeviceZ);
	float4 PrevScreenClipPrediction = mul(float4(CurrentScreenPosition, 1.0), View.ClipToPrevClip);
	float3 PrevScreenPositionPrediction = PrevScreenClipPrediction.xyz / PrevScreenClipPrediction.w;

	float4 Velocity = GBufferVelocityTexture.Load(int3(InScreenLoc,0));
	if (Velocity.x > 0.0)
	{
		// Valid velocity sample, decode and use instead of the reprojected screen position.
		float3 DecodedVelocity = DecodeVelocityFromTexture(Velocity);
		PrevScreenPositionPrediction = CurrentScreenPosition - DecodedVelocity;
	}
	// Convert predicted position to UV space
	PrevScreenPositionPrediction.xy = ScreenPosToViewportUV(PrevScreenPositionPrediction.xy);

	// Sample the depth at the reprojected position (from the previous frame's depth buffer)
	float ReprojectedDeviceZ = HistoryDepthTexture.SampleLevel(GlobalPointClampedSampler, PrevScreenPositionPrediction.xy, 0).r;

	// Determine if the reprojected position is within the history view (wasnt reprojected off screen).
	float2 ClampedReprojectedPositionUV = clamp(PrevScreenPositionPrediction.xy, HistoryBufferUVMinMax.xy, HistoryBufferUVMinMax.zw);
	bool IsPredictionOnScreen = all(ClampedReprojectedPositionUV == PrevScreenPositionPrediction.xy);

	// Populate Output
	Output.CurrentLinearDepth	  = ConvertFromDeviceZ(CurrentDeviceZ);
	Output.ReprojectedUV		  = PrevScreenPositionPrediction.xy;
	Output.ReprojectedLinearDepth = ConvertFromDeviceZ(PrevScreenPositionPrediction.z);
	Output.HistoryLinearDepth	  = ConvertFromDeviceZ(ReprojectedDeviceZ);

	return IsPredictionOnScreen;

}

// Include the platform agnostic implementation
#include "/ThirdParty/QcomShadowDenoiser/Shared/QcomShadowDenoiserReproject.h"


[numthreads(8, 8, 1)]
void ReprojectCS(uint3 DispatchThreadId : SV_DispatchThreadID, uint3 GroupId : SV_GroupID)
{
	uint2 ScreenLoc = DispatchThreadId.xy;
	//Output entire buffer size, but pixels over the 'edge' of HistoryBufferUVMinMax should be clamped.  There may also be writes outside the bounds of the outputs, but that is ok per hlsl/vulkan spec!
	uint2 ClampedScreenLoc = min(DispatchThreadId.xy, ((uint2)View.ViewSizeAndInvSize.xy) - 1);
	uint2 TileLoc = GroupId.xy;

	ReprojectOutputs Outputs;
	Reproject(ClampedScreenLoc, TileLoc, PERMUTATION_TEMPORAL_REJECTMODE, Outputs);

	OutputMomentBuffer[ScreenLoc] = Outputs.Moments;
	OutputShadowBuffer[ScreenLoc] = float4(Outputs.Shadow, 0.0, 0.0);
	OutputDistanceBuffer[ScreenLoc] = Outputs.DistanceMinMax;
}

