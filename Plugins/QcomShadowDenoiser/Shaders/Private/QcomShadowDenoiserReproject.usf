//
// Reproject the shadow value from last frame(s) into the current camera space.
// Depth reprojected into current screen space is compared with the actual current depth in order to reject occluded (invalid) values.
//

// Inputs:  current (noisy) ray traced shadows
//          current depth (from rasterization)
//			previous (reprojected and filtered) shadow value
//			previous moments
//			output moments
//			output reprojected shadow value

// Moment buffers store the 1st and 2nd moments of the shadow value and the number of frames used to accumulate these (N) xyz = (1st*N, 2nd*N, N)
// These moments are used to compute the temporal variance.

#include "/Engine/Public/Platform.ush"
#include "/Engine/Private/SceneTexturesCommon.ush"
// Include the platform specific types
#include "QcomShadowDenoiserTypes.ush"

// Shader parameters
#include "/Engine/Private/Common.ush"
#include "/Engine/Private/SceneTextureParameters.ush"
float4				ThreadIdToBufferUV;
float4				HistoryBufferUVMinMax;
Texture2D			HistoryDepthTexture;
Texture2D<float2>	InputRtShadowTexture;
Texture2D			HistoryShadowTexture;
Texture2D<float4>	HistoryMomentTexture;
Texture2D<float2>	HistoryDistanceTexture;
Texture2D<int>		InputTileClassificationTexture;
Texture2D<float2>	InputTileMinMaxTexture;
Texture2D<float>	InputFixedFilterTexture; 
RWTexture2D<float4>	OutputShadowBuffer;
RWTexture2D<float4>	OutputMomentBuffer;
RWTexture2D<float2>	OutputDistanceBuffer;

#if FEATURE_LEVEL == FEATURE_LEVEL_ES3_1
Texture2D SceneDepthTexture;
Texture2D GBufferVelocityTexture;
#define GetGlobalSampler(Filter,WrapMode) \
	View.Shared##Filter##WrapMode##Sampler
#define GlobalPointClampedSampler GetGlobalSampler(Point, Clamped)
#define GlobalBilinearClampedSampler GetGlobalSampler(Bilinear, Clamped)
#endif

// Local constants
static const float TUNING_REPROJECT_DEPTH_SENSITIVITY = 0.25;	// Larger values makes reprojected depth difference calculation more sensitive (reprojected pixels less likely to be accepted)
static const float TUNING_HISTORY_CERTAINTY_THRESHOLD = 0.05;	// Certainty less than this just gets throw away (disoccluded)
static const float TUNING_MINIMUM_UNREPROJECTED_SHADOW = 0.1;	// How much of the 'noisy' (un-reprojected) shadow from this frame to use when we have full confidence of the temporal value (smaller values make smoother shadows but slower response to input changes in cases where scene changes are not detected)

#define INPUT_RT_SHADOW_BUFFER					InputRtShadowTexture
#define INPUT_FILTERED_SHADOW_HISTORY_BUFFER	HistoryShadowTexture
#define INPUT_TILE_MINMAX_DISTANCE_BUFFER		InputTileMinMaxTexture
#define INPUT_TILE_CLASSIFICATION_BUFFER		InputTileClassificationTexture
#define INPUT_MINMAX_HISTORY_BUFFER				HistoryDistanceTexture
#define INPUT_MOMENTS_HISTORY_BUFFER			HistoryMomentTexture
#define INPUT_FIXED_FILTER_BUFFER				InputFixedFilterTexture


