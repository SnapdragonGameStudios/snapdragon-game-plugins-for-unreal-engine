<?xml version="1.0" encoding="utf-8"?>
<root xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Copy the Whisper SDK JAR that houses all needed libs -->
    <resourceCopies>
        <log text="Copying SNPE AAR..."/>
        <copyFile src="$S(AbsPluginDir)/lib/android/whisper-sdk.jar" dst="$S(BuildDir)/libs/whisper-sdk.jar"/>
        <copyDir src="$S(PluginDir)/lib/android/$S(Architecture)" dst="$S(BuildDir)/libs/$S(Architecture)"/>
    </resourceCopies>
    <gradleAdditions>
        <insert> dependencies { implementation files('libs/whisper-sdk.jar') } </insert>
    </gradleAdditions>
    <soFiles>
        <addFile src="$S(PluginDir)/lib/android/$S(Architecture)/*.so" dst="*" />
    </soFiles>
    <gameActivityClassAdditions>
        <insert>
            public String getNativeLibDir() {return getApplicationInfo().nativeLibraryDir;}
        </insert>
    </gameActivityClassAdditions>
    <androidManifestUpdates>
        <addPermission  android:name="android.permission.RECORD_AUDIO" />
        <addPermission  android:name="android.permission.READ_EXTERNAL_STORAGE" />
    </androidManifestUpdates>
</root>
